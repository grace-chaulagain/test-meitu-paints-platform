# For same-origin production hosting through the backend, leave this empty.
VITE_API_BASE_URL=

# For local development, use:
# VITE_API_BASE_URL=http://localhost:5002

# For split production hosting, use the production API origin:
# VITE_API_BASE_URL=https://api.example.com

# Public inquiry form submission endpoint. Leave blank to disable submissions.
# This is embedded into the frontend build, so use only public-safe endpoints.
VITE_INQUIRY_ENDPOINT=
